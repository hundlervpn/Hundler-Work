# DuckDNS token (from the top of your https://www.duckdns.org account page)
DUCKDNS_TOKEN=your-duckdns-token-here

# PostgreSQL password — choose any strong password (used by the db + app)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Telegram bot token from @BotFather (needed for user login / Telegram Mini App)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ---- OxaPay payments ----
# Merchant key (invoices/deposits) and payout key (withdrawals) from your OxaPay account.
OXAPAY_MERCHANT_API_KEY=your-oxapay-merchant-key
OXAPAY_PAYOUT_API_KEY=your-oxapay-payout-key
# Public URL of the app (used for OxaPay callback + return links), e.g. https://yourdomain.duckdns.org
PUBLIC_BASE_URL=https://your-domain.duckdns.org
# Optional explicit webhook URL (defaults to PUBLIC_BASE_URL + /api/oxapay/webhook)
OXAPAY_CALLBACK_URL=

# ---- Admin panel (/admin) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# Secret used to sign the admin session cookie (any long random string).
ADMIN_SESSION_SECRET=change-me-random-long-secret
