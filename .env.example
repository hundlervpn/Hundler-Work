# DuckDNS token (from the top of your https://www.duckdns.org account page)
DUCKDNS_TOKEN=your-duckdns-token-here

# External HTTPS port.
#   8443 (default) — safe: does NOT collide with the VPN node on 443.
#   443            — only if `sudo ss -tlnp | grep ':443 '` shows nothing on the host.
HTTPS_PORT=8443