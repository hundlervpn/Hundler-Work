# DuckDNS token (from the top of your https://www.duckdns.org account page)
DUCKDNS_TOKEN=your-duckdns-token-here

# PostgreSQL password — choose any strong password (used by the db + app)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Telegram bot token from @BotFather (needed for user login / Telegram Mini App)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here